<UserControl x:Class="BookmarkStudio.BookmarkManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BookmarkStudio"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:imageCatalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             mc:Ignorable="d"
             d:DesignHeight="480"
             d:DesignWidth="960"
             Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
             toolkit:Themes.UseVsTheme="True">
    <UserControl.Resources>
        <local:BookmarkColorToBrushConverter x:Key="ColorToBrushConverter" />

        <Style x:Key="BookmarkTreeViewItemStyle"
               TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarSelectedBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsSelectionActive" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarHoverOverSelectedBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextHoverOverSelectedBrushKey}}" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:FolderNodeViewModel}" ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <imaging:CrispImage Grid.Column="0"
                                    Margin="0,0,4,0"
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center">
                    <imaging:CrispImage.Style>
                        <Style TargetType="imaging:CrispImage">
                            <Setter Property="Moniker" Value="{x:Static imageCatalog:KnownMonikers.FolderClosed}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsExpanded}" Value="True">
                                    <Setter Property="Moniker" Value="{x:Static imageCatalog:KnownMonikers.FolderOpened}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </imaging:CrispImage.Style>
                </imaging:CrispImage>
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayText}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type local:BookmarkItemNodeViewModel}">
            <Grid Margin="0,1" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="10"
                        Height="10"
                        CornerRadius="2"
                        BorderThickness="1"
                        BorderBrush="SaddleBrown"
                        VerticalAlignment="Center"
                        Background="{Binding Bookmark.Color, Converter={StaticResource ColorToBrushConverter}}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayText}"
                           TextTrimming="CharacterEllipsis"
                           Margin="4,0,8,0"
                           ToolTip="{Binding Bookmark.DocumentPath}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Bookmark.RepositoryRelativePath}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0"
                           ToolTip="{Binding Bookmark.DocumentPath}" />
                <TextBlock Grid.Column="3"
                           Text="{Binding Bookmark.LineText}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Column="4"
                           HorizontalAlignment="Right"
                           Text="{Binding Bookmark.LineNumber}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TreeView x:Name="BookmarkTreeView"
                  ItemsSource="{Binding RootNodes}"
                  ItemContainerStyle="{StaticResource BookmarkTreeViewItemStyle}"
                  SelectedItemChanged="BookmarkTreeView_SelectedItemChanged"
                  PreviewMouseLeftButtonDown="BookmarkTreeView_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="BookmarkTreeView_PreviewMouseMove"
                  AllowDrop="True"
                  DragOver="BookmarkTreeView_DragOver"
                  Drop="BookmarkTreeView_Drop"
                  HorizontalContentAlignment="Stretch"
                  BorderThickness="0"
                  Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Navigate" Click="NavigateMenuItem_Click" />
                    <MenuItem Header="Copy Location" Click="CopyLocationMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="Edit Label" Click="EditLabelMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="Add Folder" Click="AddFolderMenuItem_Click" />
                    <MenuItem Header="Rename Folder" Click="RenameFolderMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="Assign Slot">
                        <MenuItem Header="1" Tag="1" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="2" Tag="2" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="3" Tag="3" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="4" Tag="4" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="5" Tag="5" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="6" Tag="6" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="7" Tag="7" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="8" Tag="8" Click="AssignSlotMenuItem_Click" />
                        <MenuItem Header="9" Tag="9" Click="AssignSlotMenuItem_Click" />
                    </MenuItem>
                    <MenuItem Header="Clear Slot" Click="ClearSlotMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="Set Color">
                        <MenuItem Header="Orange (default)" Tag="2" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Red" Tag="1" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Yellow" Tag="3" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Green" Tag="4" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Blue" Tag="5" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Purple" Tag="6" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Pink" Tag="7" Click="SetColorMenuItem_Click" />
                        <MenuItem Header="Teal" Tag="8" Click="SetColorMenuItem_Click" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Delete" Click="DeleteBookmarkMenuItem_Click" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>
