<UserControl x:Class="BookmarkStudio.BookmarkManagerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BookmarkStudio"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:imageCatalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             mc:Ignorable="d"
             d:DesignHeight="480"
             d:DesignWidth="960"
             Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
             toolkit:Themes.UseVsTheme="True">
    <UserControl.Resources>
        <local:BookmarkColorToBrushConverter x:Key="ColorToBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter" />

        <Style x:Key="TreeViewItemFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExpandCollapseToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Width="16" Height="16" Background="Transparent" Padding="5,5,5,5">
                            <Path x:Name="ExpandPath"
                                  Fill="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
                                  Data="M0,0 L0,6 L6,0 z">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="135" CenterX="3" CenterY="3" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="3" CenterY="3" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BookmarkTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="1,2,0,2" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource TreeViewItemFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="19" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Border x:Name="SelectionBd"
                                    Grid.ColumnSpan="2"
                                    Background="Transparent"
                                    SnapsToDevicePixels="True" />
                            <ToggleButton x:Name="Expander"
                                          Style="{StaticResource ExpandCollapseToggleStyle}"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Border x:Name="Bd"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Grid.Column="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBd" Property="Background" Value="#40808080" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectionBd" Property="Background" Value="#30808080" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:FolderNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <Border Padding="0,1">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Move to Solution" 
                                  Click="MoveToSolutionMenuItem_Click"
                                  Visibility="{Binding CanMoveToSolution, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <MenuItem Header="Move to Personal" 
                                  Click="MoveToPersonalMenuItem_Click"
                                  Visibility="{Binding CanMoveToPersonal, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <MenuItem Header="Rename Folder" Click="RenameFolderMenuItem_Click" 
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                        <MenuItem Header="Delete Folder" Click="DeleteFolderMenuItem_Click"
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Folder icon for non-root -->
                        <imaging:CrispImage Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Moniker="{x:Static imageCatalog:KnownMonikers.FolderClosed}"
                                            Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                        <!-- User icon for root personal -->
                        <imaging:CrispImage Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Moniker="{x:Static imageCatalog:KnownMonikers.User}"
                                            Visibility="{Binding IsPersonalRoot, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <!-- Solution icon for root solution -->
                        <imaging:CrispImage Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Moniker="{x:Static imageCatalog:KnownMonikers.Solution}"
                                            Visibility="{Binding IsSolutionRoot, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding FolderName}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type local:BookmarkItemNodeViewModel}">
            <Border Padding="0,1">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Navigate" Click="NavigateMenuItem_Click" />
                        <MenuItem Header="Copy Location" Click="CopyLocationMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Edit Label" Click="EditLabelMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Assign Slot">
                            <MenuItem Header="1" Tag="1" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="2" Tag="2" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="3" Tag="3" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="4" Tag="4" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="5" Tag="5" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="6" Tag="6" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="7" Tag="7" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="8" Tag="8" Click="AssignSlotMenuItem_Click" />
                            <MenuItem Header="9" Tag="9" Click="AssignSlotMenuItem_Click" />
                        </MenuItem>
                        <MenuItem Header="Clear Slot" Click="ClearSlotMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Set Color">
                            <MenuItem Header="Blue (default)" Tag="5" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#1E88E5" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Red" Tag="1" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#E53935" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Orange" Tag="2" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#FB8C00" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Yellow" Tag="3" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#FDD835" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Green" Tag="4" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#43A047" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Purple" Tag="6" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#8E24AA" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Pink" Tag="7" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#EC407A" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Teal" Tag="8" Click="SetColorMenuItem_Click">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="10" CornerRadius="2" Background="#00897B" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Delete" Click="DeleteBookmarkMenuItem_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,6,0"
                                CornerRadius="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Background="{Binding Bookmark.Color, Converter={StaticResource ColorToBrushConverter}}" />
                        <TextBlock Text="{Binding DisplayText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Margin="{Binding NonNameColumnMargin}"
                               Text="{Binding Bookmark.RepositoryRelativePath}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Margin="{Binding NonNameColumnMargin}"
                               Text="{Binding Bookmark.LineText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="4"
                               Margin="{Binding NonNameRightAlignedMargin}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Text="{Binding Bookmark.LineNumber}" />
                    <TextBlock Grid.Column="5"
                               Margin="{Binding NonNameRightAlignedMargin}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Text="{Binding Bookmark.SlotNumber}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarSelectedBrushKey}}"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="File" FontWeight="SemiBold" Margin="13,0,0,0" />
                <TextBlock Grid.Column="3" Text="Line Text" FontWeight="SemiBold" Margin="13,0,0,0" />
                <TextBlock Grid.Column="4" Text="Line" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,4,0" />
                <TextBlock Grid.Column="5" Text="Slot" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,4,0" />
            </Grid>
        </Border>

        <TreeView x:Name="BookmarkTreeView"
                  Grid.Row="1"
                  ItemsSource="{Binding RootNodes}"
                  SelectedItemChanged="BookmarkTreeView_SelectedItemChanged"
                  MouseDoubleClick="BookmarkTreeView_MouseDoubleClick"
                  PreviewMouseLeftButtonDown="BookmarkTreeView_PreviewMouseLeftButtonDown"
                  PreviewMouseRightButtonDown="BookmarkTreeView_PreviewMouseRightButtonDown"
                  PreviewMouseMove="BookmarkTreeView_PreviewMouseMove"
                  AllowDrop="True"
                  DragOver="BookmarkTreeView_DragOver"
                  Drop="BookmarkTreeView_Drop"
                  BorderThickness="0"
                  Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                  Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource BookmarkTreeViewItemStyle}" />
    </Grid>
</UserControl>
