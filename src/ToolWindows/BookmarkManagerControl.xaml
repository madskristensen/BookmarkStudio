<UserControl x:Class="BookmarkStudio.BookmarkManagerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BookmarkStudio"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:imageCatalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             mc:Ignorable="d"
             d:DesignHeight="480"
             d:DesignWidth="280"
             Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
             toolkit:Themes.UseVsTheme="True">
    <UserControl.Resources>
        <local:BookmarkColorToBrushConverter x:Key="ColorToBrushConverter" />
        <local:TreeViewItemToIndentConverter x:Key="IndentConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter" />
        <local:ShortcutNumberToVisibilityConverter x:Key="ShortcutNumberToVisibilityConverter" />

        <!-- Subtle selection color like Solution Explorer -->
        <SolidColorBrush x:Key="TreeViewSelectionBrush" Color="#20808080" />

        <!-- Expander toggle arrow matching VS style -->
        <Style x:Key="ExpandCollapseToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="4,4,0,4">
                            <Path x:Name="ExpandPath"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 4 4 L 0 8 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                  SnapsToDevicePixels="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="Data" Value="M 0 0 L 8 0 L 4 4 Z" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Context Menu Styles -->
        <Style x:Key="ThemedContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuBackgroundGradientBeginBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuBorderBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Grid.IsSharedSizeScope" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextActiveBrushKey}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" SharedSizeGroup="MenuItemIconColumnGroup" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemShortcutColumnGroup" />
                                    <ColumnDefinition Width="17" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconGutter"
                                        Grid.Column="0"
                                        Background="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuIconBackgroundBrushKey}}" />
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Width="16"
                                                  Height="16"
                                                  Margin="4,0" />
                                <ContentPresenter x:Name="Header"
                                                  Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="6,4,6,4"
                                                  VerticalAlignment="Center" />
                                <TextBlock x:Name="InputGestureText"
                                           Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Margin="24,4,6,4"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextInactiveBrushKey}}" />
                                <Path x:Name="Arrow"
                                      Grid.Column="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuSubmenuGlyphBrushKey}}"
                                      Data="M0,0 L4,3.5 L0,7 z"
                                      Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Right"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Background="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuBackgroundGradientBeginBrushKey}}"
                                            BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuBorderBrushKey}}"
                                            BorderThickness="1"
                                            Padding="2"
                                            Grid.IsSharedSizeScope="True">
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuItemMouseOverBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarTextInactiveBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedSeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuSeparatorBrushKey}}" />
            <Setter Property="Margin" Value="28,2,2,2" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" SharedSizeGroup="MenuItemIconColumnGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuIconBackgroundBrushKey}}" />
                            <Rectangle Grid.Column="1"
                                       Height="1"
                                       Margin="2,0"
                                       Fill="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarMenuSeparatorBrushKey}}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Folder Data Template -->
        <HierarchicalDataTemplate DataType="{x:Type local:FolderNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <Border Padding="0,2" HorizontalAlignment="Stretch" Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                        <MenuItem Header="Add Folder" Click="AddFolderMenuItem_Click"
                                  Style="{StaticResource ThemedMenuItemStyle}">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.NewFolder}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparatorStyle}" />
                        <MenuItem Header="Clear Bookmarks" 
                                  Click="ClearBookmarksMenuItem_Click"
                                  Style="{StaticResource ThemedMenuItemStyle}"
                                  InputGestureText="Del"
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityConverter}}">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.ClearBookmark}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Open Backing File" 
                                  Click="OpenBackingFileMenuItem_Click"
                                  Style="{StaticResource ThemedMenuItemStyle}"
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityConverter}}">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.JSONScript}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Rename" Click="RenameFolderMenuItem_Click" InputGestureText="F2"
                                  Style="{StaticResource ThemedMenuItemStyle}"
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.Rename}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Delete" Click="DeleteFolderMenuItem_Click" InputGestureText="Del"
                                  Style="{StaticResource ThemedMenuItemStyle}"
                                  Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.Cancel}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <!-- Folder icon for non-root -->
                    <imaging:CrispImage Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Moniker="{x:Static imageCatalog:KnownMonikers.FolderClosed}"
                                        Visibility="{Binding IsRoot, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                    <!-- User icon for root personal -->
                    <imaging:CrispImage Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Moniker="{x:Static imageCatalog:KnownMonikers.User}"
                                        Visibility="{Binding IsPersonalRoot, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <!-- Solution icon for root solution -->
                    <imaging:CrispImage Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Moniker="{x:Static imageCatalog:KnownMonikers.TeamProject}"
                                        Visibility="{Binding IsSolutionRoot, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding FolderName}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <!-- Bookmark Data Template -->
        <DataTemplate DataType="{x:Type local:BookmarkItemNodeViewModel}">
            <Border Padding="0,2" HorizontalAlignment="Stretch" Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                        <MenuItem Header="Navigate" Click="NavigateMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" InputGestureText="Enter">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.GoToLast}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Copy Location" Click="CopyLocationMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" InputGestureText="Ctrl+C" />
                        <Separator Style="{StaticResource ThemedSeparatorStyle}" />
                        <MenuItem Header="Rename" Click="EditLabelMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" InputGestureText="F2">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.Rename}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparatorStyle}" />                        <MenuItem x:Name="AssignShortcutSubmenu" Header="Assign shortcut" Style="{StaticResource ThemedMenuItemStyle}" SubmenuOpened="AssignShortcutSubmenu_Opened">
                            <MenuItem Header="1" Tag="1" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="2" Tag="2" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="3" Tag="3" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="4" Tag="4" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="5" Tag="5" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="6" Tag="6" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="7" Tag="7" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="8" Tag="8" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <MenuItem Header="9" Tag="9" Click="AssignShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                            <Separator Style="{StaticResource ThemedSeparatorStyle}" />
                            <MenuItem Header="Clear Shortcut" Click="ClearShortcutMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" />
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparatorStyle}" />
                        <MenuItem Header="Set Color" Style="{StaticResource ThemedMenuItemStyle}">
                            <MenuItem Header="Blue (default)" Tag="5" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#1E88E5" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Red" Tag="1" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#E53935" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Orange" Tag="2" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#FB8C00" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Yellow" Tag="3" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#FDD835" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Green" Tag="4" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#43A047" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Purple" Tag="6" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#8E24AA" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Pink" Tag="7" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#EC407A" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Teal" Tag="8" Click="SetColorMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                <MenuItem.Icon>
                                    <Border Width="10" Height="14" CornerRadius="3" Background="#00897B" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparatorStyle}" />
                        <MenuItem Header="Delete" Click="DeleteBookmarkMenuItem_Click" Style="{StaticResource ThemedMenuItemStyle}" InputGestureText="Del">
                            <MenuItem.Icon>
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static imageCatalog:KnownMonikers.Cancel}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0"
                          Width="14"
                          Height="14"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left">
                        <Border CornerRadius="3"
                                Background="{Binding Bookmark.Color, Converter={StaticResource ColorToBrushConverter}}" />
                        <TextBlock Text="{Binding Bookmark.ShortcutNumber}"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding Bookmark.ShortcutNumber, Converter={StaticResource ShortcutNumberToVisibilityConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="1"
                                                  ShadowDepth="0"
                                                  Opacity="0.5" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Bookmark.RepositoryRelativePath}" Opacity="0.7" />
                                <TextBlock Text="{Binding Bookmark.LineText}" FontStyle="Italic" TextTrimming="CharacterEllipsis" MaxWidth="400" />
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="8,0,8,0"
                               FontSize="11"
                               Opacity="0.5"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}:{1}">
                                <Binding Path="Bookmark.FileName" />
                                <Binding Path="Bookmark.LineNumber" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TreeView x:Name="BookmarkTreeView"
                  ItemsSource="{Binding RootNodes}"
                  SelectedItemChanged="BookmarkTreeView_SelectedItemChanged"
                  MouseDoubleClick="BookmarkTreeView_MouseDoubleClick"
                  PreviewMouseLeftButtonDown="BookmarkTreeView_PreviewMouseLeftButtonDown"
                  PreviewMouseRightButtonDown="BookmarkTreeView_PreviewMouseRightButtonDown"
                  PreviewMouseMove="BookmarkTreeView_PreviewMouseMove"
                  AllowDrop="True"
                  DragOver="BookmarkTreeView_DragOver"
                  Drop="BookmarkTreeView_Drop"
                  BorderThickness="0"
                  Padding="0,0,0,20"
                  toolkit:Themes.UseVsTheme="False"
                  Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  AutomationProperties.Name="Bookmark list"
                  AutomationProperties.HelpText="List of bookmarks organized by folder. Press Enter to navigate, Delete to remove, F2 to rename.">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <!-- Full-width selection background using negative margin + padding trick -->
                                    <Border x:Name="SelectionBd"
                                            Background="Transparent"
                                            Margin="-1000,0,0,0"
                                            Padding="1000,0,0,0" />

                                    <!-- Accent line on left edge (like Solution Explorer) -->
                                    <Rectangle x:Name="AccentLine"
                                               Width="2"
                                               HorizontalAlignment="Left"
                                               Margin="-1000,0,0,0"
                                               Fill="Transparent" />

                                    <!-- Header row with expander and content -->
                                    <Grid HorizontalAlignment="Stretch"
                                          Margin="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                          Converter={StaticResource IndentConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="19" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="Expander"
                                                      Style="{StaticResource ExpandCollapseToggle}"
                                                      ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />
                                        <ContentPresenter x:Name="PART_Header"
                                                          Grid.Column="1"
                                                          ContentSource="Header"
                                                          HorizontalAlignment="Stretch"
                                                          Margin="0,2" />
                                    </Grid>

                                    <ItemsPresenter x:Name="ItemsHost"
                                                    Grid.Row="1"
                                                    Visibility="Collapsed" />
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsExpanded" Value="True">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                    </Trigger>
                                    <!-- Selected + focused: show accent line -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True" />
                                            <Condition Property="IsSelectionActive" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="SelectionBd" Property="Background" 
                                                Value="{StaticResource TreeViewSelectionBrush}" />
                                        <Setter TargetName="AccentLine" Property="Fill" 
                                                Value="{DynamicResource {x:Static platformui:TreeViewColors.SelectedItemActiveBrushKey}}" />
                                    </MultiTrigger>
                                    <!-- Selected + unfocused: subtle background only -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True" />
                                            <Condition Property="IsSelectionActive" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="SelectionBd" Property="Background" 
                                                Value="{StaticResource TreeViewSelectionBrush}" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>

